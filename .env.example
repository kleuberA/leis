# Chave da API do Google Gemini (para o SmartParser — opcional)
GOOGLE_API_KEY=sua_chave_aqui

# Chave de autenticação da API (requerida para endpoints POST/PATCH)
API_SECRET_KEY=gere_uma_chave_segura_aqui

# Configurações da API
API_HOST=0.0.0.0
API_PORT=8000

# Origens CORS permitidas (separar por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
